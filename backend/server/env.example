# Flask Configuration
# FLASK_CONFIG: 'development' | 'production' | 'testing'
FLASK_CONFIG=development
# FLASK_DEBUG: 'true' enables Werkzeug debugger — NEVER set to 'true' in production
FLASK_DEBUG=false

# REQUIRED: Secret keys for session signing and JWT tokens
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-string
JWT_SECRET_KEY=change-me-to-another-random-string

# Database Configuration (SQLite for Windows compatibility)
DATABASE_URL=sqlite:///lunalens.db
DEV_DATABASE_URL=sqlite:///lunalens_dev.db
TEST_DATABASE_URL=sqlite:///lunalens_test.db

# Boulder Detection Configuration
BOULDER_DETECTION_MODELS_PATH=../boulder_detection/models

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/lunalens.log

# File Upload Configuration
MAX_CONTENT_LENGTH=16777216  # 16MB in bytes
UPLOAD_FOLDER=uploads

# CORS Configuration (comma-separated list of allowed origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000

# Network Security
# ALLOW_EXTERNAL_ACCESS: set to 'true' to bind to 0.0.0.0 instead of 127.0.0.1
ALLOW_EXTERNAL_ACCESS=false
# REQUIRE_HTTPS: set to 'true' to require HTTPS in production
REQUIRE_HTTPS=false

# QGIS / Lunar terrain analysis
QGIS_PYTHON=C:\Program Files\QGIS 3.40.9\bin\python-qgis-ltr.bat
QGIS_PREFIX_PATH=C:\Program Files\QGIS 3.40.9
LUNALENS_DEM_DIR=./data/dem 