# Flask Configuration
FLASK_CONFIG=development
FLASK_DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production
JWT_SECRET_KEY=your-jwt-secret-key-change-this-in-production

# Database Configuration (SQLite for Windows compatibility)
DATABASE_URL=sqlite:///lunalens.db
DEV_DATABASE_URL=sqlite:///lunalens_dev.db
TEST_DATABASE_URL=sqlite:///lunalens_test.db

# Boulder Detection Configuration
BOULDER_DETECTION_MODELS_PATH=../boulder_detection/models

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/lunalens.log

# File Upload Configuration
MAX_CONTENT_LENGTH=16777216  # 16MB in bytes
UPLOAD_FOLDER=uploads

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000 